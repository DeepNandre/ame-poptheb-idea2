# ─────────────────────────────────────────────────────────────────────────────
# Building Scanner — environment configuration
# Copy this file to `.env.local` and fill in your own keys. `.env.local` is
# gitignored. NEVER commit real keys. This .example file must only ever contain
# placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# Mapbox — REQUIRED for the 3D map + address geocoding.
# Public token (pk....). It is shipped to the browser by design — restrict it by
# URL in the Mapbox dashboard before deploying to production.
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter — OPTIONAL. Powers the natural-language command bar.
# SERVER-SIDE ONLY: the key is read by the Node backend and proxied at
# /api/agent/interpret. It is never bundled into the browser. Without a key the
# command bar still works via a keyword fallback.
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your_openrouter_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ─────────────────────────────────────────────────────────────────────────────
# OSINT / Corporate Recon (server/osint_engine.py) — OPTIONAL.
# Real-data-only: when a key is missing, that source is skipped with an honest
# empty state. No mock/demo data is ever injected.
# ─────────────────────────────────────────────────────────────────────────────

# Shodan API key — https://account.shodan.io/  (copy "Your API Key")
SHODAN_API_KEY=your_shodan_api_key

# Censys Platform Personal Access Token (modern) —
# https://accounts.censys.io/settings/personal-access-tokens
# NOTE: the Platform search API also requires an org ID AND a paid plan — free
# tokens are UI-only, so Shodan provides the exposed-device data on free tiers.
CENSYS_API_TOKEN=your_censys_personal_access_token
CENSYS_ORG_ID=

# (Optional legacy) classic Censys API ID + Secret. Leave blank if using the
# Personal Access Token above.
CENSYS_API_ID=
CENSYS_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# CCTV / RTSP discovery (server/cameradar_engine.py + server/cctvStream.mjs)
# Install once:  npm run install:cameradar   (also needs `nmap` + `ffmpeg`)
# ─────────────────────────────────────────────────────────────────────────────

# Default LAN range for CCTV discovery. Leave blank to auto-detect your subnet.
CCTV_IP_RANGE=
# Set to 1 ONLY to use the offline reference CCTV dataset for a demo.
CCTV_DEMO=0

# ─────────────────────────────────────────────────────────────────────────────
# Building Intelligence Engine (server/building.mjs + server/sources/*)
# GET /api/building?address=... aggregates every public data source for a UK
# building. REAL-DATA-ONLY: a missing key degrades that source to an honest
# "unavailable" state in the UI — no mock data is ever injected.
#
# Live with NO key (work today): Police crime, Food Standards hygiene, EA flood
# warnings, planning applications (PlanIt), postcode + council (postcodes.io),
# and coordinates (your existing VITE_MAPBOX_TOKEN above).
# ─────────────────────────────────────────────────────────────────────────────

# Ordnance Survey Data Hub — ONE free key unlocks several OS APIs.
# Create a free project at https://osdatahub.os.uk/ and add these APIs to it:
#   • Places API           → UPRN + canonical address (the resolver)
#   • Linked Identifiers   → the building's OS MasterMap TOID + street USRN
#   • Names API            → (optional) gazetteer lookups
# Free OpenData/Places tier is 50k transactions/month. Without this key the
# engine still resolves coordinates/postcode/council; only UPRN, the canonical
# address, TOID and USRN are withheld.
# (Most OTHER OS open data — Greenspace, Roads, Code-Point, BGS radon/mining/
# ground-stability layers — is keyless BULK download via api.os.uk/downloads/v1,
# not a per-building API, so it needs a local ingest step rather than a key.)
OS_PLACES_KEY=

# Companies House — registered companies at the address.
# Free key at https://developer.company-information.service.gov.uk/ (used as the
# Basic-auth username with an empty password).
COMPANIES_HOUSE_KEY=

# CQC — care home / hospital / GP inspection ratings (only for care/health sites).
# Free subscription key at the CQC developer portal (sent as Ocp-Apim-Subscription-Key).
CQC_API_KEY=

# Charity Commission — registered charities at the address.
# Free key at https://api-portal.charitycommission.gov.uk/ (Ocp-Apim-Subscription-Key).
CHARITY_COMMISSION_KEY=

# ── Phase 2 (not yet wired into live fetch; documented for setup) ──
# EPC — energy rating + floor area. Register at https://epc.opendatacommunities.org/
# (Basic auth = base64(email:key)).
EPC_EMAIL=
EPC_API_KEY=
# TfL — nearby stops + accessibility. Free app key at https://api-portal.tfl.gov.uk/
TFL_APP_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Python backend (backend/ — building-scanner migration). Loaded by backend/
# scan.py, building.py, pipeline_app.py, enricher_bridge.py (backend/.env first,
# then this project-root .env). All OPTIONAL — a missing key skips that source.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — workers/ingest.py (o3 vision floor extraction) + simulate_worker.py.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini   # optional override

# Companies House — the python backend reads COMPANIES_HOUSE_API_KEY (distinct from
# the Node server's COMPANIES_HOUSE_KEY above; the same key value works for both).
COMPANIES_HOUSE_API_KEY=

# Google Maps — OPTIONAL. Enables the OSINT scan to turn a building/company name into
# its website (Places API New → websiteUri) before attributing IP space. Requires the
# "Places API (New)" enabled on the key. Without it, resolution falls back to keyless
# DuckDuckGo + OpenStreetMap/Nominatim (lower hit-rate, can throttle).
GOOGLE_MAPS_API_KEY=

# Organizer-enricher people pipeline (people.py / enricher_bridge.py / apollo_people.py)
APOLLO_API_KEY=
BRAVE_API_KEY=
FULLENRICH_API_KEY=
# Employee finder — free key at https://hunter.io
HUNTER_API_KEY=

# Mubit (company-brain persistent memory) — placeholder; only for the real mubit-sdk.
MUBIT_API_KEY=
MUBIT_ENDPOINT=https://api.mubit.ai

# Playwright (people.py LinkedIn source — drives logged-in Chrome over CDP)
PLAYWRIGHT_PROXY=http://127.0.0.1:8888
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=1
